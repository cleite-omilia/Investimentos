{
  "name": "investimentos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx opennextjs-cloudflare dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "preview": "npx opennextjs-cloudflare build && npx wrangler dev",
    "deploy": "npx opennextjs-cloudflare build && npx wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply investimentos-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply investimentos-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.4",
    "@hookform/resolvers": "^5.2.2",
    "@opennextjs/cloudflare": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.0",
    "lucide-react": "^0.474.0",
    "next": "^15.3.0",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.71.2",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
